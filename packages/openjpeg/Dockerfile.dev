# Use Emscripten for building C/C++ to WebAssembly
FROM emscripten/emsdk:3.1.70

# Install additional dependencies
RUN apt-get update && apt-get install -y \
    git \
    cmake \
    make \
    inotify-tools \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy package files for dependencies
COPY package.json ./

# Initialize git submodules will be done via volume mount
# This allows hot-reloading of the C source code

# Default command - we'll override this in docker-compose
CMD ["/bin/bash"]
