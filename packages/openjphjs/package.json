{
  "name": "@cornerstonejs/codec-openjph",
  "version": "2.4.7-imagenio.1",
  "description": "JS/WebAssembly build of OpenJPH (Imagenio fork: -fwasm-exceptions patch)",
  "main": "dist/openjphjs.js",
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=0.14"
  },
  "exports": {
    ".": "./dist/openjphjs.js",
    "./wasm": "./dist/openjphjs.wasm",
    "./wasmjs": "./dist/openjphjs.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:ci": "yarn run test",
    "test:watch": "vitest",
    "test:benchmark": "cd test/node; node index.js",
    "build": "bash build.sh",
    "build:ci": "yarn run build",
    "build:ui": "webpack --config ./.webpack/webpack.config.js",
    "start": " webpack-dev-server --config ./.webpack/webpack.config.js",
    "prepublishOnly": "bash build.sh",
    "postpublish": "node -p -e \"require('./package.json').version\" > success_version.txt",
    "bench": "vitest bench --run"
  },
  "files": [
    "package.json",
    "README.md",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImagenioBR/codecs.git",
    "directory": "packages/openjphjs"
  },
  "author": "ImagenioBR (fork de cornerstonejs/codecs by Chris Hafey)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ImagenioBR/codecs/issues"
  },
  "homepage": "https://github.com/ImagenioBR/codecs/tree/main/packages/openjphjs#readme"
}
