{
  "version": "3.0.0",
  "packages": [
    "packages/*"
  ],
  "npmClient": "yarn",
  "command": {
    "publish": {
      "ignoreChanges": [
        "*.md",
        "*.yml",
        "*.spec.js",
        "*.test.js"
      ],
      "message": "chore(release): publish"
    },
    "version": {
      "allowBranch": "main",
      "conventionalCommits": true,
      "createRelease": "github",
      "yes": true,
      "message": "chore(release): publish [skip ci]"
    }
  },
  "$schema": "node_modules/lerna/schemas/lerna-schema.json"
}
