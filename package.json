{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "dotenv": "^14.1.0",
    "jest": "^26.6.3",
    "lerna": "^9.0.0"
  },
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "build:all": "npx lerna@9.0.0 run build:ci --parallel --stream",
    "test:all": "npx lerna@9.0.0 run test:ci --parallel --stream",
    "build:ci": "npx lerna@9.0.0 run build:ci --since main --parallel --stream",
    "test:ci": "npx lerna@9.0.0 run test:ci --since main --parallel --stream",
    "build:publish": "npx lerna@9.0.0 run build:ci --parallel --stream"
  }
}
