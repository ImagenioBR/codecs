{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "dotenv": "^14.1.0",
    "jest": "^26.6.3",
    "lerna": "^8.0.0"
  },
  "engines": {
    "node": ">=0.14"
  },
  "scripts": {
    "build:all": "lerna run build:ci --parallel --stream",
    "test:all": "lerna run test:ci --parallel --stream",
    "build:ci": "lerna run build:ci --since main --parallel --stream",
    "test:ci": "lerna run test:ci --since main --parallel --stream",
    "build:publish": "lerna run build:ci --parallel --stream"
  }
}
